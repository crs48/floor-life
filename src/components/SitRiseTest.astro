---
// The Sitting–Rising Test as a small, tasteful interactive.
// Scoring follows the study: start at 10 (5 down, 5 up); subtract 1 per
// support (hand, forearm, knee, side of leg) and 0.5 for unsteadiness.
// We are careful to frame it honestly — it measures musculoskeletal
// fitness and is an association, not a prophecy.
---

<div
  id="srt"
  class="rounded-soft border border-line bg-paper/70 p-6 sm:p-8"
  data-down="0"
  data-up="0"
  data-wobble="0"
>
  <p class="eyebrow mb-2">Try it now</p>
  <h3 class="display-3 font-display text-ink">Can you get down to the floor — and back up?</h3>
  <p class="mt-3 text-inksoft">
    Sit down to the floor and stand back up, aiming to use no hands, knees, or
    support. Start at ten and take a point off for each thing you lean on.
  </p>

  <div class="mt-6 grid gap-5 sm:grid-cols-2">
    <div class="rounded-soft border border-linesoft bg-sand/40 p-4">
      <p class="text-sm font-semibold text-ink">Going down</p>
      <p class="text-xs text-inkmuted">Supports used (hand, forearm, knee, side of leg)</p>
      <div class="mt-3 flex items-center gap-3">
        <button type="button" data-step="down" data-dir="-1" class="srt-btn" aria-label="Fewer supports going down">−</button>
        <output data-out="down" class="w-8 text-center text-xl font-semibold text-ink">0</output>
        <button type="button" data-step="down" data-dir="1" class="srt-btn" aria-label="More supports going down">+</button>
      </div>
    </div>
    <div class="rounded-soft border border-linesoft bg-sand/40 p-4">
      <p class="text-sm font-semibold text-ink">Standing up</p>
      <p class="text-xs text-inkmuted">Supports used (hand, forearm, knee, side of leg)</p>
      <div class="mt-3 flex items-center gap-3">
        <button type="button" data-step="up" data-dir="-1" class="srt-btn" aria-label="Fewer supports standing up">−</button>
        <output data-out="up" class="w-8 text-center text-xl font-semibold text-ink">0</output>
        <button type="button" data-step="up" data-dir="1" class="srt-btn" aria-label="More supports standing up">+</button>
      </div>
    </div>
  </div>

  <label class="mt-4 flex items-center gap-3 text-sm text-inksoft">
    <input type="checkbox" data-wobble class="h-4 w-4 accent-clay" />
    I wobbled or lost my balance at some point (−0.5)
  </label>

  <div class="mt-6 flex flex-col gap-2 rounded-soft bg-ink px-5 py-4 text-paper sm:flex-row sm:items-baseline sm:justify-between">
    <p class="text-sm opacity-80">Your score</p>
    <p><span data-out="score" class="font-display text-4xl">10</span><span class="opacity-70"> / 10</span></p>
  </div>
  <p data-out="reading" class="mt-3 text-[0.95rem] leading-relaxed text-inksoft">
    A perfect ten. In the research, higher scorers had markedly better survival —
    but read the next part before reading your fortune.
  </p>
  <p class="mt-3 text-xs leading-relaxed text-inkmuted">
    The Sitting–Rising Test reflects strength, flexibility, and balance. Its link
    to longevity is a real <em>association</em> — not proof that the habit itself
    adds years. It is a starting line, not a verdict, and not medical advice.
  </p>
</div>

<style>
  .srt-btn {
    display: inline-flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid var(--color-line);
    background: var(--color-paper);
    font-size: 1.25rem;
    color: var(--color-ink);
    line-height: 1;
  }
  .srt-btn:hover { border-color: var(--color-clay); }
</style>

<script>
  function initSRT() {
    const root = document.getElementById('srt');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = '1';
    const outs = {
      down: root.querySelector('[data-out="down"]'),
      up: root.querySelector('[data-out="up"]'),
      score: root.querySelector('[data-out="score"]'),
      reading: root.querySelector('[data-out="reading"]'),
    };
    const wobble = root.querySelector('[data-wobble]') as HTMLInputElement | null;
    const state = { down: 0, up: 0 };

    const readings = [
      { min: 8, text: 'Eight or above. Strong musculoskeletal fitness — the band the research links to the best survival. Keep it by living low a little every day.' },
      { min: 6, text: 'Six to seven and a half. Solid, with room to open the hips and ankles. A few minutes on the floor daily pays off quickly here.' },
      { min: 3.5, text: 'Three and a half to five and a half. The middle. This is exactly where small, patient practice — props, short sits, easy squats — moves the needle most.' },
      { min: 0, text: 'Below three and a half. Please build up gently and safely, ideally with a professional. Getting up and down more easily is a trainable skill, not a fixed fate.' },
    ];

    function render() {
      const raw = 10 - state.down - state.up - (wobble?.checked ? 0.5 : 0);
      const score = Math.max(0, raw);
      if (outs.down) outs.down.textContent = String(state.down);
      if (outs.up) outs.up.textContent = String(state.up);
      if (outs.score) outs.score.textContent = Number.isInteger(score) ? String(score) : score.toFixed(1);
      const reading = readings.find((r) => score >= r.min);
      if (outs.reading && reading) outs.reading.textContent = reading.text;
    }

    root.querySelectorAll('[data-step]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-step') as 'down' | 'up';
        const dir = Number(btn.getAttribute('data-dir'));
        state[key] = Math.min(4, Math.max(0, state[key] + dir));
        render();
      });
    });
    wobble?.addEventListener('change', render);
    render();
  }
  if (document.readyState !== 'loading') initSRT();
  else document.addEventListener('DOMContentLoaded', initSRT);
  document.addEventListener('astro:page-load', initSRT);
</script>
