---
import { site, nav } from '../lib/site';
import { href, isActive } from '../lib/url';

const current = Astro.url.pathname;
---

<header class="relative z-40 border-b border-line/70">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 sm:px-8">
    <a
      href={href('/')}
      class="group flex items-baseline gap-2 no-underline"
      aria-label={`${site.name} — home`}
    >
      <span class="font-display text-2xl font-medium tracking-tight text-ink">Floor</span>
      <span class="font-display text-2xl font-medium tracking-tight text-clay italic">Life</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={href(item.href)}
            aria-current={isActive(current, item.href) ? 'page' : undefined}
            class:list={[
              'text-sm no-underline transition-colors hover:text-claydeep',
              isActive(current, item.href) ? 'text-claydeep' : 'text-inksoft',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      type="button"
      class="inline-flex items-center gap-2 rounded-pill border border-line px-3 py-1.5 text-sm text-inksoft md:hidden"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="sr-only">Toggle menu</span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
      Menu
    </button>
  </div>

  <!-- Mobile panel -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-line/70 bg-sand/60 px-5 py-2 md:hidden"
    aria-label="Primary (mobile)"
  >
    {
      nav.map((item) => (
        <a
          href={href(item.href)}
          aria-current={isActive(current, item.href) ? 'page' : undefined}
          class="flex items-baseline justify-between gap-4 border-b border-linesoft py-3 no-underline last:border-0"
        >
          <span class="text-base text-ink">{item.label}</span>
          {item.blurb && <span class="text-xs text-inkmuted">{item.blurb}</span>}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
