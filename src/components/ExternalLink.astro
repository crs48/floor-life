---
// A curated outbound link. Non-affiliate — always rel="noopener".
// (Affiliate buy-links use AffiliateLink.astro instead.)
interface Props {
  href: string;
  title: string;
  source: string;
  note: string;
  detail?: string;
}
const { href, title, source, note, detail } = Astro.props;
---

<a
  href={href}
  rel="noopener"
  target="_blank"
  class="group flex h-full flex-col rounded-soft border border-line bg-paper/60 p-5 no-underline transition-all hover:-translate-y-0.5 hover:border-clay/50"
>
  <div class="flex items-start justify-between gap-3">
    <span class="text-xs uppercase tracking-wider text-inkmuted">{source}</span>
    <svg
      width="15"
      height="15"
      viewBox="0 0 24 24"
      fill="none"
      class="shrink-0 text-inkmuted transition-colors group-hover:text-claydeep"
      aria-hidden="true"
    >
      <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </div>
  <h3 class="mt-1.5 font-display text-lg leading-snug text-ink transition-colors group-hover:text-claydeep">
    {title}
  </h3>
  <p class="mt-2 flex-1 text-[0.9rem] leading-relaxed text-inksoft">{note}</p>
  {detail && <p class="mt-3 text-xs text-inkmuted">{detail}</p>}
</a>
