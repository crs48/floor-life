---
import { href } from '../lib/url';

interface Props {
  slug: string;
  name: string;
  otherName?: string;
  difficulty: 'gentle' | 'moderate' | 'advanced';
  summary: string;
}
const { slug, name, otherName, difficulty, summary } = Astro.props;

const pill = {
  gentle: 'bg-sage/15 text-sagedeep',
  moderate: 'bg-straw/40 text-claydeep',
  advanced: 'bg-clay/15 text-claydeep',
}[difficulty];
---

<a
  href={href(`/positions/${slug}`)}
  class="group flex h-full flex-col rounded-soft border border-line bg-paper/60 p-6 no-underline transition-all hover:-translate-y-0.5 hover:border-clay/50"
>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-xl font-display text-ink">{name}</h3>
      {otherName && <p class="mt-0.5 text-sm italic text-inkmuted">{otherName}</p>}
    </div>
    <span class:list={['shrink-0 rounded-pill px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-wider', pill]}>
      {difficulty}
    </span>
  </div>
  <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-inksoft">{summary}</p>
  <span class="mt-4 text-sm font-semibold text-claydeep">
    Cues & cautions →
  </span>
</a>
