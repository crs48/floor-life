---
import AffiliateLink from './AffiliateLink.astro';

export interface Product {
  name: string;
  brand: string;
  category: string;
  price: string;
  priceNote?: string;
  affiliateUrl: string;
  retailer: string;
  tier: 'budget' | 'mid' | 'premium';
  rating?: number;
  pros: string[];
  cons: string[];
  bestFor: string;
  verdict: string;
  featured?: boolean;
}
interface Props {
  product: Product;
}
const { product } = Astro.props;

const tierLabel = { budget: 'Budget', mid: 'Mid', premium: 'Premium' }[product.tier];
const tierPill = {
  budget: 'bg-sage/15 text-sagedeep',
  mid: 'bg-straw/40 text-claydeep',
  premium: 'bg-clay/15 text-claydeep',
}[product.tier];
---

<article
  class:list={[
    'flex h-full flex-col rounded-soft border bg-paper/60 p-6',
    product.featured ? 'border-clay/40' : 'border-line',
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-wider text-inkmuted">{product.brand}</p>
      <h3 class="mt-0.5 text-xl font-display text-ink">{product.name}</h3>
    </div>
    <span class:list={['shrink-0 rounded-pill px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-wider', tierPill]}>
      {tierLabel}
    </span>
  </div>

  <div class="mt-3 flex items-baseline gap-3">
    <span class="text-lg font-semibold text-ink">{product.price}</span>
    {
      product.rating && (
        <span class="inline-flex items-center gap-1 text-sm text-inkmuted">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-straw" aria-hidden="true">
            <path d="m12 3 2.6 5.6L20.5 9l-4.3 4.1 1.1 6L12 16.3 6.7 19.1l1.1-6L3.5 9l5.9-.4L12 3Z" />
          </svg>
          {product.rating.toFixed(1)}
        </span>
      )
    }
  </div>

  <p class="mt-4 text-sm leading-relaxed text-inksoft">
    <span class="font-semibold text-ink">Best for:</span> {product.bestFor}
  </p>

  <div class="mt-4 grid gap-3 sm:grid-cols-2">
    <ul class="space-y-1.5 text-sm text-inksoft">
      {product.pros.map((p) => (
        <li class="flex gap-2">
          <span class="mt-0.5 text-sagedeep" aria-hidden="true">+</span>
          <span>{p}</span>
        </li>
      ))}
    </ul>
    <ul class="space-y-1.5 text-sm text-inksoft">
      {product.cons.map((c) => (
        <li class="flex gap-2">
          <span class="mt-0.5 text-claydeep" aria-hidden="true">−</span>
          <span>{c}</span>
        </li>
      ))}
    </ul>
  </div>

  <p class="mt-4 border-l-2 border-straw pl-3 text-sm italic leading-relaxed text-ink">
    {product.verdict}
  </p>

  <div class="mt-5 flex items-center justify-between border-t border-linesoft pt-4">
    <span class="text-xs text-inkmuted">{product.retailer}</span>
    <AffiliateLink href={product.affiliateUrl} />
  </div>
  {product.priceNote && <p class="mt-2 text-xs text-inkmuted">{product.priceNote}</p>}
</article>
