---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// A captioned, credited figure over astro:assets <Image>. Optimises at
// build (WebP + responsive srcset via Sharp), reserves space to prevent
// CLS, and handles the base path automatically because `src` is imported.
// Drop real photography in by importing it and passing it here.
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  credit?: string;
  creditUrl?: string;
  priority?: boolean;
  class?: string;
}
const { src, alt, caption, credit, creditUrl, priority = false, class: className = '' } =
  Astro.props;
---

<figure class:list={['not-prose', className]}>
  <div class="overflow-hidden rounded-soft border border-line bg-sand/40">
    <Image src={src} alt={alt} priority={priority} class="h-auto w-full" />
  </div>
  {
    (caption || credit) && (
      <figcaption class="mt-2 flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1 text-xs text-inkmuted">
        {caption && <span>{caption}</span>}
        {credit &&
          (creditUrl ? (
            <a href={creditUrl} rel="noopener" target="_blank" class="text-inkmuted underline decoration-line">
              {credit}
            </a>
          ) : (
            <span>{credit}</span>
          ))}
      </figcaption>
    )
  }
</figure>
