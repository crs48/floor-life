---
interface Props {
  eyebrow: string;
  title: string;
  lede?: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<header class="mx-auto max-w-6xl px-5 pt-16 sm:px-8 sm:pt-24">
  <div class="max-w-3xl">
    <p class="eyebrow mb-4">{eyebrow}</p>
    <h1 class="display-1 font-display text-ink">{title}</h1>
    {lede && <p class="mt-6 max-w-2xl text-xl leading-relaxed text-inksoft">{lede}</p>}
  </div>
</header>
