---
// Every outbound buy link goes through here so it always carries
// rel="sponsored nofollow" (per Google's guidance) and opens safely.
// The FTC disclosure lives near the links at the page/section level;
// see /disclosure.
interface Props {
  href: string;
  class?: string;
  label?: string;
}
const { href, class: className = '', label } = Astro.props;
---

<a
  href={href}
  rel="sponsored nofollow noopener"
  target="_blank"
  data-affiliate="true"
  class:list={[
    'inline-flex items-center gap-1.5 font-semibold text-claydeep no-underline transition-opacity hover:opacity-80',
    className,
  ]}
>
  <slot>{label ?? 'Check current price'}</slot>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M7 17 17 7M9 7h8v8"
      stroke="currentColor"
      stroke-width="1.7"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
  </svg>
</a>
