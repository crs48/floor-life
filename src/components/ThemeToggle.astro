---
// Light/dark toggle. The no-flash script in BaseLayout sets the initial
// theme; this just flips and persists it. Init is idempotent and re-runs
// on astro:page-load so it survives view transitions.
---

<button
  type="button"
  data-theme-toggle
  class="inline-flex h-9 w-9 items-center justify-center rounded-pill border border-line text-inksoft transition-colors hover:border-clay hover:text-claydeep"
  aria-label="Toggle light and dark theme"
  title="Toggle theme"
>
  <svg data-icon="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4.2" />
    <path d="M12 2.5v2.2M12 19.3v2.2M4.2 4.2l1.6 1.6M18.2 18.2l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.2 19.8l1.6-1.6M18.2 5.8l1.6-1.6" />
  </svg>
  <svg data-icon="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 14.5A8 8 0 0 1 9.5 4a8 8 0 1 0 10.5 10.5Z" />
  </svg>
</button>

<style>
  /* Show the icon for the theme you'd switch TO. */
  [data-theme-toggle] [data-icon='sun'] { display: none; }
  [data-theme-toggle] [data-icon='moon'] { display: block; }
  :root[data-theme='dark'] [data-theme-toggle] [data-icon='sun'] { display: block; }
  :root[data-theme='dark'] [data-theme-toggle] [data-icon='moon'] { display: none; }
</style>

<script>
  function initThemeToggles() {
    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      if ((btn as HTMLElement).dataset.bound) return;
      (btn as HTMLElement).dataset.bound = '1';
      btn.addEventListener('click', () => {
        const next =
          document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    });
  }
  if (document.readyState !== 'loading') initThemeToggles();
  else document.addEventListener('DOMContentLoaded', initThemeToggles);
  document.addEventListener('astro:page-load', initThemeToggles);
</script>
