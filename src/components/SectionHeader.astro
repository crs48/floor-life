---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, intro, align = 'left', class: className = '' } = Astro.props;
---

<div
  class:list={[
    'max-w-2xl',
    align === 'center' && 'mx-auto text-center',
    className,
  ]}
>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="display-3 font-display">{title}</h2>
  {intro && <p class="mt-4 text-lg leading-relaxed text-inksoft">{intro}</p>}
</div>
