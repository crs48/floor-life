---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ExternalLink from '../components/ExternalLink.astro';
import Callout from '../components/Callout.astro';
import { href } from '../lib/url';

const all = await getCollection('resources');
const byKind = (kind: string) =>
  all.filter((r) => r.data.kind === kind).sort((a, b) => a.data.order - b.data.order);

const sections = [
  {
    kind: 'community',
    eyebrow: 'Find your people',
    title: 'Communities',
    intro:
      'There is no single home for floor living yet — so the conversation is scattered across a dozen adjacent places. Here is the map.',
  },
  {
    kind: 'watch',
    eyebrow: 'Watch & learn',
    title: 'Videos & channels',
    intro:
      'The movement teachers and Japan-living documentarians worth your evenings.',
  },
  {
    kind: 'reading',
    eyebrow: 'Long-form',
    title: 'Worth reading',
    intro:
      'The essays, home tours, and journalism that make the case better than we can.',
  },
  {
    kind: 'research',
    eyebrow: 'Go to the source',
    title: 'The research',
    intro: 'The primary studies behind the claims — read them yourself.',
  },
];
---

<BaseLayout
  title="Resources"
  description="A curated map of the floor-living internet — the Reddit communities, YouTube channels, essays, home tours, and primary research worth your time."
>
  <PageHeader
    eyebrow="The map"
    title="The floor-living library"
    lede="We'd rather send you to the best of the web than pretend we're the only voice. Here's the map — curated, honestly labelled, and updated as we find better."
  />

  <div class="mx-auto mt-8 max-w-6xl px-5 sm:px-8">
    <Callout variant="note" title="A note on the gap">
      In researching this, one thing stood out: <strong>there is no dedicated,
      active hub for floor living.</strong> The topic lives in the margins of
      minimalism, mobility, and Japanese-living communities. If that ever
      changes — maybe it starts here — we'll point you to it first.
    </Callout>
  </div>

  {
    sections.map((section) => {
      const items = byKind(section.kind);
      if (items.length === 0) return null;
      return (
        <section class="mx-auto mt-16 max-w-6xl px-5 sm:px-8">
          <div class="max-w-2xl">
            <p class="eyebrow text-sagedeep">{section.eyebrow}</p>
            <h2 class="mt-2 display-3 font-display text-ink">{section.title}</h2>
            <p class="mt-3 text-inksoft">{section.intro}</p>
          </div>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((r) => (
              <ExternalLink
                href={r.data.url}
                title={r.data.title}
                source={r.data.source}
                note={r.data.note}
                detail={r.data.detail}
              />
            ))}
          </div>
        </section>
      );
    })
  }

  <section class="mx-auto mt-20 max-w-6xl px-5 sm:px-8">
    <p class="text-sm text-inkmuted">
      Know something great we've missed? These lists are hand-kept — the best
      additions come from readers. Links are external and open in a new tab;
      inclusion isn't endorsement of everything a source has ever said. See our
      <a href={href('/disclosure')} class="text-claydeep">disclosure</a>.
    </p>
  </section>
</BaseLayout>
