---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { href } from '../../lib/url';

const posts = (await getCollection('journal', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Journal"
  description="Long-form writing on floor living — the evidence, the how-to, the gear, and the quieter case for living closer to the ground."
>
  <PageHeader
    eyebrow="Long-form reading"
    title="The Journal"
    lede="Essays and guides for the floor-curious and the already-committed — always with the caveats left in."
  />

  <section class="mx-auto mt-14 max-w-3xl px-5 pb-8 sm:px-8">
    <ul class="divide-y divide-line">
      {
        posts.map((post) => (
          <li>
            <a
              href={href(`/journal/${post.id}`)}
              class="group flex flex-col gap-2 py-7 no-underline"
            >
              <div class="flex items-center gap-3 text-xs">
                <span class="eyebrow text-sagedeep">{post.data.category}</span>
                <span class="text-inkmuted">{fmt(post.data.pubDate)}</span>
                {post.data.readingMinutes && (
                  <span class="text-inkmuted">· {post.data.readingMinutes} min</span>
                )}
              </div>
              <h2 class="font-display text-2xl text-ink transition-colors group-hover:text-claydeep">
                {post.data.title}
              </h2>
              <p class="text-[0.95rem] leading-relaxed text-inksoft">{post.data.description}</p>
              <span class="mt-1 text-sm font-semibold text-claydeep">Read →</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
